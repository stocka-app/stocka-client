# ─────────────────────────────────────────────────────────────────────────────
# Playwright E2E environment configuration
# Copy to .env.e2e and fill in values for local development.
# CI uses GitHub Actions environment variables instead.
# ─────────────────────────────────────────────────────────────────────────────

# Direct PostgreSQL connection to the dedicated e2e database.
# NEVER point this at stocka_db (development) or test_w* (backend e2e) databases.
PW_DATABASE_URL=postgresql://stocka:stocka_dev_password@localhost:5434/stocka_playwright

# Frontend base URL — where Vite dev server listens
PW_BASE_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# One-time setup (run once, before the first test run):
#
#   1. Create the e2e database:
#      psql -h localhost -p 5434 -U stocka -c "CREATE DATABASE stocka_playwright;"
#
#   2. Run backend migrations against it:
#      cd ../stocka-server
#      DB_DATABASE=stocka_playwright npm run migration:run
#
#   3. Start the backend pointing to the e2e database:
#      DB_DATABASE=stocka_playwright npm run start:dev
#
#   4. Run the e2e tests in a separate terminal:
#      npm run test:e2e
# ─────────────────────────────────────────────────────────────────────────────
